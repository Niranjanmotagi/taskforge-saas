# ==============================================================================
# TaskForge — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env files.
# ==============================================================================

# ------------------------------------------------------------------------------
# General
# ------------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=TaskForge
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
API_PORT=5000

# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------------------
POSTGRES_USER=taskforge
POSTGRES_PASSWORD=taskforge_dev_password
POSTGRES_DB=taskforge
POSTGRES_PORT=5432
DATABASE_URL=postgresql://taskforge:taskforge_dev_password@localhost:5432/taskforge?schema=public

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# JWT / Auth
# ------------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_REMEMBER_EXPIRES_IN=30d
COOKIE_SECRET=change-me-cookie-secret-min-32-characters
COOKIE_DOMAIN=localhost
BCRYPT_SALT_ROUNDS=12

# ------------------------------------------------------------------------------
# OAuth — Google
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ------------------------------------------------------------------------------
# OAuth — GitHub
# ------------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/github/callback

# ------------------------------------------------------------------------------
# Email (Nodemailer / SMTP)
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
EMAIL_FROM_NAME=TaskForge
EMAIL_FROM_ADDRESS=no-reply@taskforge.io

# ------------------------------------------------------------------------------
# Cloudinary
# ------------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=taskforge

# ------------------------------------------------------------------------------
# Stripe
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# ------------------------------------------------------------------------------
# AI (Anthropic Claude)
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=20

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=debug

# ------------------------------------------------------------------------------
# Frontend (Next.js) — must be prefixed NEXT_PUBLIC_ to reach the browser
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME=TaskForge
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
